# Copy to .env and adjust as needed. docker-compose reads these (with the compose
# defaults as fallback). The ONLY local<->AWS difference is DYNAMODB_ENDPOINT + creds.

# --- DynamoDB / AWS ---
# Local: point at dynamodb-local. AWS: leave empty so boto3 uses the real endpoint.
DYNAMODB_ENDPOINT=http://dynamodb-local:8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# --- Table names (one per aggregate, AD-3) ---
PRODUCTS_TABLE=Products
CARTS_TABLE=Carts
ORDERS_TABLE=Orders

# --- Domain ---
# Flat shipping placeholder in integer minor units / cents (AD-6). 500 = $5.00.
FLAT_SHIPPING=500

# --- HTTP ---
CORS_ORIGINS=http://localhost:5173

# --- Frontend (Vite) ---
VITE_API_BASE_URL=http://localhost:8000
